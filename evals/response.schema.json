{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "posture",
    "stage",
    "decision",
    "end_state",
    "layer_percentages",
    "entropy_call",
    "taste_call",
    "truth_source",
    "primary_blocker",
    "smallest_next_move",
    "stop_list",
    "evidence_needed"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "posture": {
      "type": "string",
      "enum": ["trivial", "governed"]
    },
    "stage": {
      "type": "string",
      "enum": ["0-90", "90-100"]
    },
    "decision": {
      "type": "string",
      "enum": ["stop", "judge", "dispatch", "act", "accept", "ask"]
    },
    "end_state": {
      "type": "string",
      "minLength": 1
    },
    "layer_percentages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer", "fit"],
        "properties": {
          "layer": {
            "type": "string",
            "minLength": 1
          },
          "fit": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        }
      }
    },
    "entropy_call": {
      "type": "string",
      "minLength": 1
    },
    "taste_call": {
      "type": "string",
      "minLength": 1
    },
    "truth_source": {
      "type": "string",
      "minLength": 1
    },
    "primary_blocker": {
      "type": "string",
      "minLength": 1
    },
    "smallest_next_move": {
      "type": "string",
      "minLength": 1
    },
    "stop_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_needed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
