{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "posture",
    "stage",
    "decision",
    "end_state",
    "entropy_call",
    "taste_call",
    "truth_source",
    "primary_blocker",
    "smallest_next_move",
    "project_choice",
    "cut_line",
    "proof_pivot",
    "evidence_skill",
    "evidence_skill_reason",
    "stop_list",
    "evidence_needed"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "posture": {
      "type": "string",
      "enum": ["trivial", "governed"]
    },
    "stage": {
      "type": "string",
      "enum": ["0-90", "90-100"]
    },
    "decision": {
      "type": "string",
      "enum": ["stop", "judge", "dispatch", "act", "accept", "ask"]
    },
    "end_state": {
      "type": "string",
      "minLength": 1
    },
    "entropy_call": {
      "type": "string",
      "minLength": 1
    },
    "taste_call": {
      "type": "string",
      "minLength": 1
    },
    "truth_source": {
      "type": "string",
      "minLength": 1
    },
    "primary_blocker": {
      "type": "string",
      "minLength": 1
    },
    "smallest_next_move": {
      "type": "string",
      "minLength": 1
    },
    "project_choice": {
      "type": "string",
      "minLength": 1
    },
    "cut_line": {
      "type": "string",
      "minLength": 1
    },
    "proof_pivot": {
      "type": "string",
      "minLength": 1
    },
    "evidence_skill": {
      "type": "string",
      "enum": [
        "none",
        "targeted_research",
        "architecture_precedent",
        "project_truth_audit",
        "evidence_verification",
        "option_stress_test"
      ]
    },
    "evidence_skill_reason": {
      "type": "string",
      "minLength": 1
    },
    "stop_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_needed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
